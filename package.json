{
  "name": "prowlai",
  "version": "0.1.0",
  "description": "CLI-first QA testing tool for deterministic Playwright flows.",
  "type": "module",
  "bin": {
    "prowlai": "dist/cli/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsup src/cli/index.ts --format esm,cjs --sourcemap --out-dir dist",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "dotenv": "^16.6.1",
    "ora": "^8.1.1",
    "playwright": "^1.50.1",
    "yaml": "^2.6.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.13.1",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "typescript": "^5.7.3",
    "tsup": "^8.3.5",
    "vitest": "^2.1.8"
  }
}
